{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api/app",
  "targets": {
    "serve": {
      "command": "uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "apps/api"
      }
    },
    "test": {
      "command": "pytest -v",
      "options": {
        "cwd": "apps/api"
      }
    },
    "lint": {
      "command": "ruff check .",
      "options": {
        "cwd": "apps/api"
      }
    },
    "format": {
      "command": "ruff format .",
      "options": {
        "cwd": "apps/api"
      }
    }
  }
}
